{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodePatch",
  "type": "object",
  "required": [
    "patch_id",
    "file_path",
    "engine_id",
    "operation",
    "diff_ref",
    "undo_token_ref",
    "no_secret_in_diff"
  ],
  "properties": {
    "patch_id": {
      "type": "string"
    },
    "file_path": {
      "type": "string"
    },
    "engine_id": {
      "type": "string"
    },
    "operation": {
      "type": "string",
      "enum": [
        "edit",
        "refactor",
        "add",
        "remove",
        "replace"
      ]
    },
    "diff_ref": {
      "type": "string"
    },
    "undo_token_ref": {
      "type": "string"
    },
    "no_secret_in_diff": {
      "type": "boolean"
    },
    "risk_level": {
      "type": "string"
    }
  }
}