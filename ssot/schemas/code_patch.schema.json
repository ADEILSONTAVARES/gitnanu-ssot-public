{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "code_patch.schema.json",
  "title": "CodePatch",
  "type": "object",
  "required": [
    "patch_id",
    "mode",
    "target",
    "operation",
    "diff_preview",
    "undo_token"
  ],
  "properties": {
    "patch_id": {
      "type": "string",
      "pattern": "^CP-[A-Z0-9]+-[0-9]{4}$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "M04_CODE_PATCH"
      ]
    },
    "target": {
      "type": "object",
      "required": [
        "surface",
        "studio",
        "file_path",
        "line_start",
        "line_end"
      ],
      "properties": {
        "surface": {
          "type": "string"
        },
        "studio": {
          "type": "string",
          "pattern": "^S[0-5][0-9]$"
        },
        "file_path": {
          "type": "string"
        },
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "operation": {
      "type": "string",
      "enum": [
        "EDIT",
        "REFACTOR",
        "ADD",
        "DELETE",
        "EXPLAIN",
        "TEST"
      ]
    },
    "diff_preview": {
      "type": "object",
      "required": [
        "before",
        "after"
      ],
      "properties": {
        "before": {
          "type": "string"
        },
        "after": {
          "type": "string"
        },
        "lines_changed": {
          "type": "integer"
        }
      }
    },
    "undo_token": {
      "type": "string"
    },
    "test_ref": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "score_target": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    }
  },
  "additionalProperties": false
}