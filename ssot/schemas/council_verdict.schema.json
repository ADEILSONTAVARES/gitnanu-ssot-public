{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "council_verdict.schema.json",
  "title": "CouncilVerdict",
  "type": "object",
  "required": [
    "verdict_id",
    "patch_id",
    "council",
    "decision",
    "score_final",
    "timestamp"
  ],
  "properties": {
    "verdict_id": {
      "type": "string",
      "pattern": "^CV-[A-Z0-9]+-[0-9]{4}$"
    },
    "patch_id": {
      "type": "string"
    },
    "council": {
      "type": "object",
      "required": [
        "J1",
        "J2",
        "J3"
      ],
      "properties": {
        "J1": {
          "type": "object",
          "required": [
            "score",
            "pass"
          ],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "pass": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "J2": {
          "type": "object",
          "required": [
            "score",
            "pass"
          ],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "pass": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "J3": {
          "type": "object",
          "required": [
            "score",
            "pass"
          ],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "pass": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    },
    "decision": {
      "type": "string",
      "enum": [
        "PASS_STRICT",
        "PASS_CI",
        "FAIL",
        "FAIL_STRICT",
        "CONDITIONAL"
      ]
    },
    "score_final": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_ref": {
      "type": "string"
    }
  },
  "additionalProperties": false
}