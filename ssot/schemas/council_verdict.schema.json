{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CouncilVerdict",
  "type": "object",
  "required": [
    "verdict_id",
    "task_ref",
    "judges",
    "votes",
    "consensus"
  ],
  "properties": {
    "verdict_id": {
      "type": "string"
    },
    "task_ref": {
      "type": "string"
    },
    "judges": {
      "type": "array",
      "minItems": 3
    },
    "votes": {
      "type": "object"
    },
    "consensus": {
      "type": "string",
      "enum": [
        "UNANIMOUS_PASS",
        "MAJORITY_PASS",
        "FAIL"
      ]
    }
  }
}