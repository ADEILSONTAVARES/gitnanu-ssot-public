{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "image_patch.schema.json",
  "title": "ImagePatch",
  "type": "object",
  "required": [
    "patch_id",
    "mode",
    "engine",
    "target",
    "operation",
    "diff_preview",
    "undo_token"
  ],
  "properties": {
    "patch_id": {
      "type": "string",
      "pattern": "^IP-[A-Z0-9]+-[0-9]{4}$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "M01_VISUAL_PATCH"
      ]
    },
    "engine": {
      "type": "string",
      "enum": [
        "M01",
        "M02",
        "M03",
        "M04",
        "M05",
        "M06",
        "M07",
        "M08",
        "M09",
        "M10",
        "M11",
        "M12",
        "M13"
      ]
    },
    "target": {
      "type": "object",
      "required": [
        "surface",
        "studio",
        "element_id"
      ],
      "properties": {
        "surface": {
          "type": "string"
        },
        "studio": {
          "type": "string",
          "pattern": "^S[0-5][0-9]$"
        },
        "element_id": {
          "type": "string"
        }
      }
    },
    "operation": {
      "type": "string",
      "enum": [
        "REPLACE",
        "ADJUST",
        "CROP",
        "RESIZE",
        "COLOR",
        "FILTER",
        "OVERLAY"
      ]
    },
    "diff_preview": {
      "type": "object",
      "required": [
        "before_ref",
        "after_ref"
      ],
      "properties": {
        "before_ref": {
          "type": "string"
        },
        "after_ref": {
          "type": "string"
        }
      }
    },
    "undo_token": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "score_target": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    }
  },
  "additionalProperties": false
}