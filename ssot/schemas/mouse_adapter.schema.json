{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mouse_adapter.schema.json",
  "title": "MouseAdapter",
  "description": "Schema canonico para adapters de engine do Mouse Inteligente OG10",
  "type": "object",
  "required": ["adapter_id", "engine", "family", "input_types", "output_types", "config"],
  "properties": {
    "adapter_id": {"type": "string", "pattern": "^MA-[A-Z0-9]+-[0-9]{2}$"},
    "engine": {"type": "string"},
    "family": {"type": "string", "enum": ["M01","M02","M03","M04","M05","M06","M07","M08","M09","M10","M11","M12","M13"]},
    "input_types": {
      "type": "array",
      "items": {"type": "string", "enum": ["image","video","pdf","code","text","3d","audio"]},
      "minItems": 1
    },
    "output_types": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "config": {
      "type": "object",
      "required": ["layer", "shadow_band", "score_min"],
      "properties": {
        "layer": {"type": "string", "enum": ["L0","L1","L2","L3"]},
        "shadow_band": {"type": "string"},
        "score_min": {"type": "number", "minimum": 0, "maximum": 10},
        "timeout_ms": {"type": "integer"},
        "retry_max": {"type": "integer", "default": 3}
      }
    },
    "status": {"type": "string", "enum": ["ACTIVE","CANDIDATE_VERIFY","DEPRECATED"]},
    "ssot_pointer": {"type": "string"}
  },
  "additionalProperties": false
}