{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MouseAuditTrail",
  "type": "object",
  "required": [
    "trail_id",
    "session_id",
    "events",
    "final_state"
  ],
  "properties": {
    "trail_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "events": {
      "type": "array"
    },
    "final_state": {
      "type": "string",
      "enum": [
        "COMMITTED",
        "ROLLED_BACK",
        "PARTIAL"
      ]
    }
  }
}